# .env
# MongoDB
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=school
MONGO_COLLECTION=users

# API MOS.RU настройки
ACADEMIC_YEAR_ID=13
SCHOOL_ID=28
REQUEST_TIMEOUT=30

# API Sferum настройки (замените на реальные)
SFERUM_API_URL=https://api.sferum.ru/v1
SFERUM_CONTACTS_ENDPOINT=/contacts
SFERUM_TIMEOUT=10

# Заголовки MOS.RU
PROFILE_ID=16073051
X_MES_HOSTID=9
X_MES_SUBSYSTEM=teacherweb
AID=13

# Настройки производительности
BATCH_SIZE=500
MAX_WORKERS=10
PAGINATION_PER_PAGE=300

# Логирование
LOG_LEVEL=INFO
LOG_FILE=sync.log

# Токены (опционально, можно вводить интерактивно)
# MOS_RU_TOKEN=your_token_here
# SFERUM_TOKEN=your_token_here